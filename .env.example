# ─── Mock data (default) ──────────────────────────────────────────────────────
# Set to "false" to connect to a real Jamf Pro instance
USE_MOCK_DATA=true

# ─── Jamf Pro API (only needed when USE_MOCK_DATA=false) ──────────────────────
JAMF_PRO_URL=https://yourinstance.jamfcloud.com
JAMF_API_CLIENT_ID=your-oauth-client-id
JAMF_API_CLIENT_SECRET=your-oauth-client-secret
